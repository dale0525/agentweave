{
  "name": "agentweave-desktop",
  "version": "0.1.0",
  "license": "(Apache-2.0 OR MIT)",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "build": "vite build && npm run build:electron",
    "build:electron": "npm run build:workers && vite build --config vite.electron.config.ts --mode electron-main && vite build --config vite.electron.config.ts --mode electron-preload && vite build --config vite.electron.config.ts --mode electron-approval-preload && node scripts/check-preload-bundles.mjs",
    "build:workers": "npm run build:gateway && npm run build:entitlement",
    "build:gateway": "node ../../scripts/build-cloudflare-gateway.mjs",
    "build:entitlement": "node ../../scripts/build-cloudflare-entitlement.mjs",
    "dev": "vite",
    "package:macos": "node scripts/package-macos.mjs",
    "start": "electron .",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@radix-ui/themes": "^3.3.0",
    "diff": "^8.0.4",
    "katex": "^0.16.47",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "esbuild": "^0.21.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
