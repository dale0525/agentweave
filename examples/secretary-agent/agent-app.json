{
  "schemaVersion": 1,
  "appId": "com.example.secretary-agent",
  "package": {
    "id": "com.example.secretary-agent.app",
    "version": "0.1.0"
  },
  "compatibility": {
    "runtime": ">=0.1.0, <0.2.0",
    "platforms": [
      "desktop",
      "android",
      "server"
    ]
  },
  "requires": {
    "packages": [
      {
        "id": "agentweave.foundation.memory",
        "version": "=0.1.0"
      },
      {
        "id": "agentweave.foundation.mail",
        "version": "=0.1.0"
      },
      {
        "id": "com.example.secretary.routines",
        "version": "=0.1.0"
      }
    ],
    "capabilities": [
      "memory-provider",
      "provenance",
      "retention-policy",
      "reversible-history",
      "durable-actions",
      "approval-engine",
      "credential-vault",
      "mail-connector",
      "host-tools"
    ],
    "runtimeTools": [
      "memory_search",
      "memory_get",
      "memory_propose",
      "memory_confirm",
      "memory_update",
      "memory_forget",
      "memory_export",
      "mail_accounts_list",
      "mail_account_status",
      "mail_account_connect",
      "mail_account_disconnect",
      "mailboxes_list",
      "mail_threads_list",
      "mail_thread_get",
      "mail_search",
      "mail_message_get",
      "mail_body_read",
      "mail_attachment_read",
      "mail_mark_read",
      "mail_archive",
      "mail_move",
      "mail_draft_create",
      "mail_reply_draft",
      "mail_forward_draft",
      "mail_draft_get",
      "mail_draft_update",
      "mail_draft_delete",
      "mail_send_preview",
      "mail_send",
      "mail_delivery_status"
    ],
    "connectors": [
      "agentweave-mail"
    ]
  },
  "features": [
    "action-center",
    "memory-management",
    "mail-workflows"
  ],
  "policy": {
    "externalSideEffects": "require_approval",
    "network": "declared_only",
    "backgroundExecution": "disabled",
    "memoryPersistence": "local_only",
    "skillManagement": "disabled"
  },
  "branding": {
    "displayName": "私人秘书",
    "shortName": "秘书",
    "description": "由 AgentWeave Framework 组合 Mail、Memory 与应用自定义 Skill 的参考 Agent App。",
    "accentColor": "#315C49"
  },
  "appearance": {
    "defaultTheme": "vscode.dark-2026",
    "themes": {
      "builtins": [
        "vscode.dark-2026",
        "vscode.light-2026",
        "vscode.dark-plus",
        "vscode.dark-modern",
        "vscode.light-plus",
        "vscode.light-modern",
        "vscode.visual-studio-dark",
        "vscode.visual-studio-light",
        "vscode.high-contrast-dark",
        "vscode.high-contrast-light",
        "vscode.abyss",
        "vscode.kimbie-dark",
        "vscode.monokai",
        "vscode.monokai-dimmed",
        "vscode.quiet-light",
        "vscode.red",
        "vscode.solarized-dark",
        "vscode.solarized-light",
        "vscode.tomorrow-night-blue"
      ],
      "custom": []
    }
  },
  "localization": {
    "defaultLocale": "zh-CN",
    "locales": [
      {
        "id": "en",
        "label": "English",
        "resource": "locales/en.json"
      },
      {
        "id": "zh-CN",
        "label": "简体中文",
        "resource": "locales/zh-CN.json"
      }
    ]
  },
  "instructions": {
    "system": "prompts/system.md",
    "developer": "prompts/developer.md",
    "additional": []
  }
}
