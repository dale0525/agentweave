{
  "schemaVersion": 1,
  "providers": {
    "identity": {
      "id": "agentweave.identity.oidc",
      "version": "0.1.0",
      "publicConfig": {
        "preset": "generic",
        "issuer": "https://identity.example.test",
        "clientId": "managed-gateway-agent",
        "audience": "https://managed-gateway-agent.example.workers.dev",
        "scopes": [
          "openid",
          "profile",
          "offline_access"
        ],
        "redirectUri": "http://127.0.0.1:8978/agentweave/identity/callback",
        "gatewayAlgorithm": "RS256",
        "gatewayDeviceMode": "disabled",
        "gatewayRequireNbf": false
      }
    },
    "entitlement": {
      "id": "agentweave.entitlements.http",
      "version": "0.1.0",
      "publicConfig": {
        "baseUrl": "https://entitlements.example.test",
        "timeoutMilliseconds": 10000,
        "maxResponseBytes": 65536
      }
    },
    "gateway": {
      "id": "cloudflare-workers",
      "version": "0.1.0",
      "publicConfig": {
        "upstreamBaseUrl": "https://api.openai.com/v1",
        "upstreamAuthentication": "bearer",
        "maxBodyBytes": 4194304,
        "maxOutputTokens": 16384,
        "maxTools": 128,
        "requestBaseUnits": 1,
        "deploymentMaxRequests": 10000000,
        "deploymentMaxUnits": 1000000000000,
        "deploymentConcurrency": 100,
        "tenantConcurrency": 20,
        "deviceConcurrency": 1
      }
    }
  },
  "modelAccess": {
    "configurationPolicy": "app_managed",
    "profile": {
      "providerId": "cloudflare-gateway",
      "endpointType": "responses",
      "baseUrl": "https://managed-gateway-agent.example.workers.dev/v1",
      "modelName": "approved-model",
      "authentication": "user_identity",
      "headers": {}
    }
  },
  "deployment": {
    "provider": "cloudflare",
    "cloudflare": {
      "accountId": "00000000000000000000000000000000",
      "workerName": "managed-gateway-agent",
      "environment": "production"
    }
  }
}
