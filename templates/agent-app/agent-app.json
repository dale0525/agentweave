{
  "schemaVersion": 1,
  "appId": "{{APP_ID}}",
  "package": {
    "id": "{{PACKAGE_ID}}",
    "version": "0.1.0"
  },
  "compatibility": {
    "runtime": ">=0.1.0, <0.2.0",
    "platforms": [
      "desktop",
      "server"
    ]
  },
  "requires": {
    "packages": [
      {
        "id": "generalagent.core.filesystem",
        "version": "=0.1.0"
      }
    ],
    "capabilities": [
      "shell.process"
    ],
    "runtimeTools": [],
    "connectors": []
  },
  "features": [],
  "policy": {
    "externalSideEffects": "require_approval",
    "network": "deny",
    "backgroundExecution": "disabled",
    "memoryPersistence": "disabled",
    "skillManagement": "disabled"
  },
  "branding": {
    "displayName": "{{APP_NAME}}"
  },
  "appearance": {
    "defaultTheme": "vscode.dark-2026",
    "themes": {
      "builtins": [
        "vscode.dark-2026",
        "vscode.light-2026",
        "vscode.dark-plus",
        "vscode.dark-modern",
        "vscode.light-plus",
        "vscode.light-modern",
        "vscode.visual-studio-dark",
        "vscode.visual-studio-light",
        "vscode.high-contrast-dark",
        "vscode.high-contrast-light",
        "vscode.abyss",
        "vscode.kimbie-dark",
        "vscode.monokai",
        "vscode.monokai-dimmed",
        "vscode.quiet-light",
        "vscode.red",
        "vscode.solarized-dark",
        "vscode.solarized-light",
        "vscode.tomorrow-night-blue"
      ],
      "custom": []
    }
  },
  "localization": {
    "defaultLocale": "en",
    "locales": [
      {
        "id": "en",
        "label": "English",
        "resource": "locales/en.json"
      },
      {
        "id": "zh-CN",
        "label": "简体中文",
        "resource": "locales/zh-CN.json"
      }
    ]
  },
  "instructions": {
    "system": "prompts/system.md",
    "developer": "prompts/developer.md",
    "additional": []
  }
}
